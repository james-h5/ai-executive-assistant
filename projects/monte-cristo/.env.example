# ElevenLabs — get an API key from elevenlabs.io > Profile > API Keys (see root .env — shared across the EA repo)
ELEVENLABS_API_KEY=

# ElevenLabs voice ID — pick or clone a voice in the Voice Library that sounds like the Count
# (deep, composed, a little formal), then copy its Voice ID from the voice's settings page
ELEVENLABS_VOICE_ID=
