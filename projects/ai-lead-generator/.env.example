# Firecrawl — get from firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Anthropic — get from console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# ClickUp — get from app.clickup.com/settings/apps
CLICKUP_API_KEY=

# ClickUp list ID — right-click your target list in ClickUp > Copy link > grab the ID from the URL
CLICKUP_LIST_ID=

# ClickUp "Draft Message" custom field ID (see root .env — shared across the EA repo)
CLICKUP_DRAFT_FIELD_ID=

# Trigger.dev — get from cloud.trigger.dev/projects > your project > API keys
TRIGGER_SECRET_KEY=
